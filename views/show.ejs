<% layout("/layouts/boilerplate") %>

<body>
  <div class="row">
    <div class="col-lg-8 col-md-10 offset-lg-2 offset-md-1 mt-4">
      <h2 class="mb-4"><%= data.title %></h2>

      <div class="card mb-4">
        <img src="<%= data.image %>" class="card-img-top show-img" alt="listing-img">
        <div class="card-body">
          <h5 class="card-text mt-3">Owner: <i><%= data.owner.username %></i></h5>
          <p class="card-text"><%= data.description %></p>
          <p class="card-text fw-bold">₹ <%= data.price.toLocaleString("en-IN") %></p>
          <p class="card-text"><%= data.location %>, <%= data.country %></p>
        </div>
      </div>
      <% if (currUser && data.owner && data.owner._id.equals(currUser._id)) { %>
        <div class="d-flex gap-3 mb-5">
          <a href="/listings/<%= data._id %>/edit" class="btn btn-primary">Edit</a>

          <form action="/listings/<%= data._id %>?_method=DELETE" method="POST">
            <button class="btn btn-danger">Delete</button>
          </form>
        </div>
      <% } %>

      <!-- Review Form (unchanged) -->
      <div class="card p-4 shadow-sm">
        <h4 class="mb-3">Leave a Review</h4>

        <form 
          action="/listings/<%= data._id %>/reviews" 
          method="POST" 
          class="needs-validation" 
          novalidate
        >
          <div class="mb-3">
            <label for="rating" class="form-label fw-semibold">Rating</label>
            <div class="d-flex align-items-center gap-3">
              <input 
                type="range" 
                min="1" 
                max="5" 
                id="rating" 
                name="review[rating]" 
                class="form-range flex-grow-1"
                required
                oninput="this.nextElementSibling.innerText = this.value"
              >
              <span class="badge bg-primary fs-6">3</span>
            </div>
            <div class="invalid-feedback">
              Please select a rating between 1 and 5.
            </div>
          </div>

          <div class="mb-3">
            <label for="comment" class="form-label fw-semibold">Comment</label>
            <textarea 
              name="review[comment]" 
              id="comment" 
              rows="4" 
              class="form-control" 
              placeholder="Write your review here..."
              required
              minlength="20"
            ></textarea>
            <div class="invalid-feedback">
              Please enter at least 20 characters for your comment.
            </div>
          </div>
          
          <button class="btn btn-success px-4" type="submit">Submit Review</button>
        </form>

        <hr>

        <!-- All Reviews Section (updated per image style) -->
        <h4 class="mb-3">All Reviews</h4>

        <% if (data.reviews && data.reviews.length > 0) { %>
          <% for (review of data.reviews) { %>
            <div class="card shadow-sm mb-3 border-0 p-4">
              <div class="card-body">
                <h5 class="card-title text-primary fw-semibold">
                  <i class="bi bi-person-circle me-2"></i>
                  <%= review.author ? review.author.username : "Anonymous" %>
                </h5>
                <p class="card-text mb-2"><%= review.comment %></p>
                <p class="card-text mb-0 text-muted">
                  ⭐ <%= review.rating %> / 5
                </p>
                <% if (currUser && review.author && review.author._id.equals(currUser._id)) { %>
                  <form action="/listings/<%= data._id %>/reviews/<%= review._id %>?_method=DELETE" method="POST">
                    <button class="btn btn-danger mt-3">Delete</button>
                  </form>
                <% } %>
              </div>
            </div>
          <% } %>
        <% } else { %>
          <p class="text-muted">No reviews yet. Be the first to leave one!</p>
        <% } %>

      </div>
    </div>
  </div>

  <!-- Bootstrap Form Validation Script -->
  <script>
    (function () {
      'use strict';
      const forms = document.querySelectorAll('.needs-validation');

      Array.from(forms).forEach(form => {
        form.addEventListener('submit', event => {
          if (!form.checkValidity()) {
            event.preventDefault();
            event.stopPropagation();
          }
          form.classList.add('was-validated');
        }, false);
      });
    })();
  </script>
</body>
